# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=development

# Wallet authorization
# Comma-separated EVM addresses that can control the agent.
OWNER_ADDRESSES=0x0000000000000000000000000000000000000000
AGENT_ID=hermes-eigen-dev
EIP712_CHAIN_ID=11155111
EIP712_VERIFYING_CONTRACT=0x0000000000000000000000000000000000000001

# Runtime persistence. On EigenCompute, use /mnt/disks/userdata.
DATA_DIR=.data

# mock: returns deterministic local records.
# hermes: invokes HERMES_COMMAND and writes the prompt to stdin.
RUNNER_MODE=mock
HERMES_COMMAND=hermes
HERMES_TIMEOUT_MS=120000

# Optional policy limits.
MAX_COMMAND_BYTES=4096
ALLOWED_SCOPES=chat,research,code,wallet-read
